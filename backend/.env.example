# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/portfolio
# or MongoDB Atlas:
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/portfolio

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRE=7d

# Admin seed credentials (used once by `npm run seed`)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Dhruv Patel

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Cloudinary (optional for remote uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=portfolio

# File upload limits (bytes)
MAX_FILE_SIZE=5242880
